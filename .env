# ============================================================
#  .env.example — Labour Law AI Platform (Anthropic-powered)
# ============================================================
#  1. Copy this file:   copy .env.example .env   (Windows)
#                       cp  .env.example  .env   (Linux/Mac)
#  2. Fill in your values — especially ANTHROPIC_API_KEY.
#  3. NEVER commit .env to git — it contains your secret key.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Labour Law AI
APP_VERSION=1.0.0
DEBUG=false

# ── Anthropic API key ─────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Starts with:     sk-ant-...
ANTHROPIC_API_KEY= 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

# ── Claude model selection ────────────────────────────────────
# Default (balanced speed + quality — recommended):
CLAUDE_MODEL=claude-sonnet-4-6

# Fast model — used for quiz generation, bulk summarisation:
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# Smart model — used for complex legal Q&A:
CLAUDE_MODEL_SMART=claude-opus-4-6

CLAUDE_TEMPERATURE=0.2
# NOTE: Anthropic temperature range is 0.0–1.0 (not 0.0–2.0 like OpenAI)
CLAUDE_MAX_TOKENS=2048

# ── Embeddings (offline, no API key needed) ───────────────────
# Anthropic does not provide an embeddings API.
# sentence-transformers runs 100% locally — free and private.
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ── Claude Vision OCR (optional) ─────────────────────────────
# Set to true to use Claude Haiku as a fallback OCR engine
# for scanned PDFs that Tesseract struggles with.
# Uses API tokens — leave false if you want fully offline OCR.
USE_CLAUDE_VISION_OCR=false

# ── Tesseract OCR binary ──────────────────────────────────────
# Windows default install path:
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac:
# TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=eng
OCR_DPI=300

# ── Database ─────────────────────────────────────────────────
# Leave blank to use default: database/labour_law.db
# DB_PATH=C:\MyProject\database\labour_law.db

# ── Server ───────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_PORT=8501

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log   # uses default if blank
